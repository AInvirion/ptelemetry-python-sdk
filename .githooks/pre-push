#!/bin/bash
# Pre-push hook: Run Codex review before pushing

echo "🔍 Running Codex review..."

# Check if codex is installed
if ! command -v codex &> /dev/null; then
    echo "⚠️  Codex not found. Install with: npm install -g @ainvirion/codex"
    echo "Skipping Codex review..."
    exit 0
fi

# Run Codex checks
codex review --fail-on-issues || {
    echo "❌ Codex review failed. Fix issues before pushing."
    exit 1
}

codex security --fail-on-issues || {
    echo "❌ Codex security check failed. Fix issues before pushing."
    exit 1
}

codex duplicates --fail-on-issues || {
    echo "❌ Codex found duplicate code. Refactor before pushing."
    exit 1
}

codex dead-code --fail-on-issues || {
    echo "❌ Codex found dead code. Clean up before pushing."
    exit 1
}

echo "✅ Codex review passed!"
exit 0
